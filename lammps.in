# General
units           metal
dimension       3
atom_style      atomic
neighbor        0.3 bin


# Structure
boundary        p p p
read_data       structure.lammps
mass 1 10.81
mass 2 14.007
mass 3 78.971
mass 4 183.84
mass 5 78.971
mass 6 78.971
mass 7 10.81
mass 8 14.007

# potential definitions
pair_style hybrid/overlay sw/mod sw/mod tersoff tersoff kolmogorov/crespi/z 14.0 kolmogorov/crespi/z 14.0 kolmogorov/crespi/z 14.0 kolmogorov/crespi/z 14.0 kolmogorov/crespi/z 14.0 kolmogorov/crespi/z 14.0 kolmogorov/crespi/z 14.0 kolmogorov/crespi/z 14.0 kolmogorov/crespi/z 14.0 kolmogorov/crespi/z 14.0 kolmogorov/crespi/z 14.0 kolmogorov/crespi/z 14.0 kolmogorov/crespi/z 14.0 kolmogorov/crespi/z 14.0 lj/cut 10.0
# Number of interlayer interactions = 14

# intralayer interactions
pair_coeff * * sw/mod 1 tmd.sw B N Se NULL NULL NULL NULL NULL
pair_coeff * * sw/mod 2 tmd.sw NULL NULL NULL W Se Se NULL NULL
pair_coeff * * tersoff 1 BNC.tersoff B N NULL NULL NULL NULL NULL NULL
pair_coeff * * tersoff 2 BNC.tersoff NULL NULL B N NULL NULL NULL NULL

pair_coeff * * lj/cut 0.0 3.4

# interlayer interaction
pair_coeff 1 1 kolmogorov/crespi/z 1 SeBN.KC B NULL NULL NULL NULL NULL NULL NULL
pair_coeff 1 2 kolmogorov/crespi/z 2 SeBN.KC B N NULL NULL NULL NULL NULL NULL
pair_coeff 1 3 kolmogorov/crespi/z 3 SeBN.KC B NULL Se NULL NULL NULL NULL NULL
pair_coeff 2 1 kolmogorov/crespi/z 4 SeBN.KC B N NULL NULL NULL NULL NULL NULL
pair_coeff 2 2 kolmogorov/crespi/z 5 SeBN.KC NULL N NULL NULL NULL NULL NULL NULL
pair_coeff 2 3 kolmogorov/crespi/z 6 SeBN.KC NULL N Se NULL NULL NULL NULL NULL
pair_coeff 1 4 kolmogorov/crespi/z 7 MoWSSe.KC W NULL NULL W NULL NULL NULL NULL
pair_coeff 2 4 kolmogorov/crespi/z 8 MoWSSe.KC NULL Se NULL W NULL NULL NULL NULL
pair_coeff 4 3 kolmogorov/crespi/z 9 SeBN.KC NULL NULL Se W NULL NULL NULL NULL
pair_coeff 4 4 kolmogorov/crespi/z 10 SeBN.KC NULL NULL NULL W NULL NULL NULL NULL
pair_coeff 5 3 kolmogorov/crespi/z 11 SeBN.KC NULL NULL Se NULL Se NULL NULL NULL
pair_coeff 5 4 kolmogorov/crespi/z 12 SeBN.KC NULL NULL NULL W Se NULL NULL NULL
pair_coeff 6 3 kolmogorov/crespi/z 13 SeBN.KC NULL NULL Se NULL NULL Se NULL NULL
pair_coeff 6 4 kolmogorov/crespi/z 14 SeBN.KC NULL NULL NULL W NULL Se NULL NULL

# Optimize at 0 K
dump            1 all custom 400 dump.minimization id type x y z
thermo          500
min_style       fire
minimize        0.0 1.0e-4 1000000 1000000
write_dump all atom dump.Final
print "Done!"
