# Neighbor settings
neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes

# Optimization
dump            1 all custom 100 dump.minimization id type x y z
thermo          1000
thermo_style    custom step pe press
min_style       fire
minimize        1.0e-10 1.0e-12 100000 1000000
undump          1
write_dump      all custom dump.Final id type x y z modify sort id
print "Done!"
