#1 General
units           metal
dimension       3
atom_style      atomic
neighbor        0.3 bin

#2 Structure
boundary        p p p
read_data       structure.lammps
mass 1 183.84
mass 2 78.971
mass 3 78.971
mass 4 183.84
mass 5 78.971
mass 6 78.971

#3 Potential definitions
pair_style hybrid/overlay sw/mod sw/mod kolmogorov/crespi/z 14.0 kolmogorov/crespi/z 14.0 kolmogorov/crespi/z 14.0 kolmogorov/crespi/z 14.0 lj/cut 10.0

#4 Intralayer interactions
pair_coeff * * sw/mod 1 tmd.sw W Se Se NULL NULL NULL
pair_coeff * * sw/mod 2 tmd.sw NULL NULL NULL W Se Se

#5 Interlayer interactions
pair_coeff 1 4 kolmogorov/crespi/z 1 MoWSSe.KC W NULL NULL W NULL NULL
pair_coeff 1 5 kolmogorov/crespi/z 2 MoWSSe.KC W NULL NULL NULL Se NULL
pair_coeff 3 4 kolmogorov/crespi/z 3 MoWSSe.KC NULL NULL Se W NULL NULL
pair_coeff 3 5 kolmogorov/crespi/z 4 MoWSSe.KC NULL NULL Se NULL Se NULL
pair_coeff * * lj/cut 0.0 3.4

#6 Optimize at 0 K
dump            1 all custom 400 dump.minimization id type x y z
min_style       fire
minimize        0.0 1.0e-8 1000000 1000000
undump          1
write_dump      all custom dump.Final id type x y z modify sort id
print "Done!"
